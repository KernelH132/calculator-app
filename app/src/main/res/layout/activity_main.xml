<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090D16"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- BANNER BUTTON -->
    <Button
        android:id="@+id/btnOpenBonus"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#8957E5"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="✨  OPEN MATRIX &amp; STATS MODE"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

    <!-- DISPLAY SCREEN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111622"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:letterSpacing="0.05"
            android:textColor="#8B949E"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:text="0"
            android:textColor="#F0F6FC"
            android:textSize="44sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- SCROLLABLE SCIENTIFIC BAR -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginBottom="6dp"
        android:scrollbars="none">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal">
            <Button android:id="@+id/btnSinh" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="sinh" android:textColor="#58A6FF" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnCosh" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="cosh" android:textColor="#58A6FF" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnTanh" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="tanh" android:textColor="#58A6FF" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnFact" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="!" android:textColor="#FF7B72" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnNpr" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginEnd="6dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="nPr" android:textColor="#D2A8FF" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnNcr" android:layout_width="wrap_content" android:layout_height="match_parent" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="nCr" android:textColor="#D2A8FF" app:cornerRadius="10dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- KEYPAD ROWS -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btnAC" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#DA3633" android:insetTop="0dp" android:insetBottom="0dp" android:text="AC" android:textColor="#FFFFFF" android:textStyle="bold" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnDel" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#21262D" android:insetTop="0dp" android:insetBottom="0dp" android:text="DEL" android:textColor="#FF7B72" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnOpenP" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#21262D" android:insetTop="0dp" android:insetBottom="0dp" android:text="(" android:textColor="#D2A8FF" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnCloseP" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#21262D" android:insetTop="0dp" android:insetBottom="0dp" android:text=")" android:textColor="#D2A8FF" app:cornerRadius="14dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btnSin" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="sin" android:textColor="#3FB950" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnCos" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="cos" android:textColor="#3FB950" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnTan" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="tan" android:textColor="#3FB950" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnPower" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="^" android:textColor="#58A6FF" app:cornerRadius="14dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="7" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="8" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="9" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnDivide" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1F6FEB" android:insetTop="0dp" android:insetBottom="0dp" android:text="/" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="14dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="4" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="5" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="6" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnMultiply" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1F6FEB" android:insetTop="0dp" android:insetBottom="0dp" android:text="*" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="14dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="1" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="2" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="3" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnMinus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1F6FEB" android:insetTop="0dp" android:insetBottom="0dp" android:text="-" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="14dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="54dp" android:orientation="horizontal">
        <Button android:id="@+id/btnDot" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="." android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1C2128" android:insetTop="0dp" android:insetBottom="0dp" android:text="0" android:textColor="#E6EDF3" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnSqrt" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#161B22" android:insetTop="0dp" android:insetBottom="0dp" android:text="√" android:textColor="#3FB950" android:textSize="18sp" app:cornerRadius="14dp"/>
        <Button android:id="@+id/btnPlus" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:backgroundTint="#1F6FEB" android:insetTop="0dp" android:insetBottom="0dp" android:text="+" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" app:cornerRadius="14dp"/>
    </LinearLayout>

    <!--EQUALS BUTTON -->
    <Button
        android:id="@+id/btnEquals"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_margin="3dp"
        android:backgroundTint="#238636"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="="
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:cornerRadius="16dp" />

</LinearLayout>